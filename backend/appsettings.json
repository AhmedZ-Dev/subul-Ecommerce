{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ImageStorage": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp", ".gif"]
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://localhost:3001",
      "http://127.0.0.1:3000",
      "http://127.0.0.1:3001"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=subul-Ecommerce;Username=postgres;Password=postgres;Pooling=true;Minimum Pool Size=1;Maximum Pool Size=100;"
  },
  "Jwt": {
    "Secret": "REPLACE_WITH_32+_CHAR_SECRET_IN_LOCAL_OVERRIDES",
    "Issuer": "subul-admin",
    "Audience": "subul-admin-panel",
    "AccessTokenMinutes": 480
  }
}
